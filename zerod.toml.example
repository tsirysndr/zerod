# zerod.toml — copy to ./zerod.toml, $XDG_CONFIG_HOME/zerod/zerod.toml, or /etc/zerod.toml

[server]
# All-interfaces by default so the daemon is reachable from the LAN.
# Set to "127.0.0.1:50151" if you only want loopback (and plan to drive
# zerod over SSH / WireGuard / Tailscale).
bind = "0.0.0.0:50151"
# Leave empty to fall back to the ZEROD_BEARER_TOKEN env var, otherwise a
# random token is generated and logged at startup. Strongly recommended to
# set this explicitly when bind is non-loopback.
bearer_token = ""

[mdns]
# Advertise this daemon on the LAN as `_zerod._tcp.local.` so clients can
# discover it without --host. Empty `name` uses the machine hostname.
enabled = true
name = ""

[systemd]
# Only units listed here can be controlled via the SystemdService API.
# Acts as an allowlist so the gRPC server can't be turned into a generic
# remote systemctl.
units = [
  "snapserver.service",
  "snapclient.service",
  "shairport-sync.service",
  "squeezelite.service",
]

# Each [[configs]] entry maps a logical key (used as the gRPC argument) to a
# file path on this host plus an optional systemd unit to reload/restart after
# a successful write. Set `unit = ""` to disable the post-write action for that
# entry.

[[configs]]
key = "snapserver"
path = "/etc/snapserver.conf"
unit = "snapserver.service"

[[configs]]
key = "snapclient"
path = "/etc/default/snapclient"
unit = "snapclient.service"

[[configs]]
key = "shairport"
path = "/etc/shairport-sync.conf"
unit = "shairport-sync.service"

[[configs]]
key = "squeezelite"
path = "/etc/default/squeezelite"
unit = "squeezelite.service"

[snapcast]
# When enabled, zerod connects to a local snapserver's JSON-RPC port on
# startup and exposes SnapcastService (clients, groups, streams).
# Disabled → the service is still reachable but every RPC returns
# FAILED_PRECONDITION (reflection-based UIs still see it exists).
enabled = false
host = "127.0.0.1"
port = 1705
# Forward snapserver push notifications onto the in-process event bus so
# `zerod events tail --filter snap` catches external `snapctl` changes.
forward_notifications = true

[librespot]
# When enabled, StreamService.SpotifyStart spawns a librespot subprocess
# wired into the same audio sink as HLS/DASH. Install librespot via
# `apt install librespot` (Debian/Ubuntu) or `brew install librespot`.
enabled = false
# Resolved against $PATH when not absolute.
binary = "librespot"
# Device name as it appears in the Spotify app's Devices list.
name = "zerod"
# 96 / 160 / 320 kbps.
bitrate = 320
# Where librespot stores credentials. Empty → librespot's default
# (current directory). --disable-audio-cache is always passed, so this
# is creds only — pick a persistent path so you don't re-pair every boot.
cache_path = ""

[bluetooth.a2dp]
# Make the Pi advertise as a Bluetooth speaker. zerod registers a BlueZ
# pairing agent and delegates the actual audio path to bluealsa-aplay
# (install `bluez-alsa-utils` on the device). The unit name below is
# auto-added to the systemd allowlist when enabled.
enabled = false
bluealsa_aplay_unit = "bluealsa-aplay.service"
# Skip the RespondPairing flow and accept every prompt. Convenient for
# kiosks; risky on a shared LAN.
auto_accept_pairings = false
# Friendly name shown to phones. Empty → leave the adapter alias alone.
adapter_alias = "zerod"
# Flip the adapter discoverable at server boot. Set false to defer to
# the `a2dp enable` RPC.
discoverable_on_boot = true
# Discoverable window in seconds. 0 → discoverable forever.
discoverable_timeout_secs = 0
